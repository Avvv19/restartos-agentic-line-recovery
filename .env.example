# =============================================================================
# RestartOS live model providers.
#
# !!! ROTATE/REVOKE ANY KEYS YOU EXPOSED DURING TESTING !!!
#    NVIDIA NIM:   https://build.nvidia.com/   -> revoke + reissue
#    Groq:         https://console.groq.com/keys
#    Google AI:    https://aistudio.google.com/apikey
#
# Architecture: author tiers (DEEP_DIAGNOSIS, PLANNING) run on NVIDIA NIM.
# Verifier tier runs on a DIFFERENT family (Groq Llama) for anti-collusion.
# Optional third ring: Gemini for tiebreaker votes.
#
# The system runs fully offline on a deterministic mock provider if no keys
# are set. Real providers activate automatically when their API key is present.
# =============================================================================

# --- NVIDIA NIM (author: deep diagnosis + planning) ---
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# --- Groq (verifier: anti-collusion, different family) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Gemini (optional 3rd verifier ring / knowledge tier) ---
# Use a Google AI Studio key (starts with AIza...). OAuth tokens (AQ.*) will 401.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash

# --- Optional first-party Anthropic / OpenAI fallbacks ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Local / open models (Ollama). Set ENABLE_OLLAMA=1 and have `ollama serve` running. ---
RESTARTOS_ENABLE_OLLAMA=0
OLLAMA_HOST=http://localhost:11434

# --- Infrastructure (defaults match docker-compose.yml) ---
QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql://restartos:restartos@localhost:5432/restartos

# =============================================================================
# LIVE MODE — wire RestartOS to real plant systems instead of the simulators.
# Leave RESTARTOS_LIVE=0 to keep everything on the in-repo synthetic plant.
# =============================================================================
RESTARTOS_LIVE=0

# --- OT side: read-only Historian (OSIsoft PI Web API or compatible) ---
PI_BASE_URL=
PI_TOKEN=
PI_TOKEN_ENV=PI_TOKEN

# --- IT side: CMMS (pick a backend) ---
#   fiix    → recommended for trials (free tier, REST + Bearer)
#   maximo  → IBM Maximo customers
#   sim     → keep writing to _it_state/it_state.json (default)
CMMS_BACKEND=sim
CMMS_BASE_URL=
CMMS_TOKEN=
CMMS_TOKEN_ENV=CMMS_TOKEN

# --- IT side: HRIS for shift roster + certifications ---
#   bamboo  → BambooHR REST (HTTP Basic)
#   sim     → read _data/hr/shift_roster.csv (default)
HRIS_BACKEND=sim
BAMBOO_BASE_URL=https://api.bamboohr.com
BAMBOO_SUBDOMAIN=
BAMBOO_API_KEY=
BAMBOO_TOKEN_ENV=BAMBOO_API_KEY

# --- IT side: Slack incoming webhook for tech notifications ---
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_ENV=SLACK_WEBHOOK_URL

# --- TLS verification (set 0 ONLY for plant self-signed certs in isolated networks) ---
RESTARTOS_VERIFY_TLS=1

# --- Runtime flags ---
# Set to 1 to enable the "demo replan" path (intentional hallucination -> catch -> recover).
# Off by default in production runs (it doubles planner+verifier latency).
RESTARTOS_DEMO_REPLAN=0

# Override dataset location (defaults to ./_data)
# RESTARTOS_DATA=/abs/path/to/_data
